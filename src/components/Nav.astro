---
const links = [
  { href: "#servizi", label: "Servizi" },
  { href: "#chi-siamo", label: "Chi siamo" },
  { href: "#perche", label: "Perché Petito" },
  { href: "#processo", label: "Metodo" },
  { href: "#portfolio", label: "Lavori" },
];
---

<header class="nav" data-nav>
  <div class="nav__inner">
    <a href="#top" class="nav__brand" aria-label="Petito Costruzioni — torna su">
      <img src="/brand/logo-oro.png" alt="" width="40" height="40" />
      <span class="nav__word">Petito<span class="nav__sub">Costruzioni</span></span>
    </a>

    <nav class="nav__links" aria-label="Navigazione principale">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <a href="#contatti" class="btn nav__cta">
      Richiedi sopralluogo
      <span class="btn__arrow" aria-hidden="true">→</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: fixed; inset-block-start: 0; inset-inline: 0; z-index: 100;
    padding: var(--space-md) var(--gutter);
    transition: transform var(--dur-mid) var(--ease-out);
  }
  .nav__inner {
    max-width: var(--container); margin-inline: auto;
    display: flex; align-items: center; gap: var(--space-lg);
    padding: 0.55rem 0.6rem 0.55rem 1.1rem;
    background: oklch(13% 0.004 60 / 0.55);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    transition: background var(--dur-mid) var(--ease-out), border-color var(--dur-mid) var(--ease-out);
  }
  :global([data-nav].is-scrolled) .nav__inner {
    background: oklch(11% 0.004 60 / 0.82);
    border-color: var(--color-line-strong);
  }
  .nav__brand { display: flex; align-items: center; gap: 0.65rem; margin-inline-end: auto; }
  .nav__brand img { border-radius: var(--radius-sm); }
  .nav__word {
    font-family: var(--font-display); text-transform: uppercase;
    font-size: var(--text-2xl); letter-spacing: 0.04em; line-height: 1;
    display: flex; flex-direction: column;
  }
  .nav__sub {
    font-family: var(--font-mono); font-size: 0.56rem; letter-spacing: 0.3em;
    color: var(--color-fg-faint); margin-top: 3px;
  }
  .nav__links { display: flex; gap: var(--space-lg); align-items: center; }
  .nav__links a {
    font-size: var(--text-sm); font-weight: 600; color: var(--color-fg-dim);
    position: relative; padding-block: 0.25rem;
    transition: color var(--dur-fast) var(--ease-out);
    white-space: nowrap;
  }
  .nav__links a::after {
    content: ""; position: absolute; inset-block-end: 0; inset-inline-start: 0;
    width: 100%; height: 1px; background: var(--color-accent);
    transform: scaleX(0); transform-origin: left; transition: transform var(--dur-mid) var(--ease-out);
  }
  .nav__links a:hover { color: var(--color-fg); }
  .nav__links a:hover::after { transform: scaleX(1); }
  .nav__cta { padding: 0.7rem 1.2rem; font-size: var(--text-xs); white-space: nowrap; }

  @media (max-width: 900px) {
    .nav__links { display: none; }
  }
  @media (max-width: 560px) {
    .nav__cta span { display: none; }
    .nav__cta { padding: 0.7rem 1.1rem; }
    .nav__word { font-size: var(--text-xl); }
  }
</style>
