---
const lavori = [
  { cat: "Residenziale", t: "Attico, Napoli", ph: "IMG · attico ristrutturato, living di lusso", span: "wide", img: "/img/lavoro-attico.jpg" },
  { cat: "Sanitario", t: "Studio dentistico, Caserta", ph: "IMG · studio dentistico, reception elegante", span: "tall", img: "/img/lavoro-dentistico.jpg" },
  { cat: "Business", t: "Sede direzionale, Roma", ph: "IMG · ufficio/sede aziendale di rappresentanza", span: "", img: "/img/lavoro-ufficio.jpg" },
  { cat: "Restauro", t: "Facciata storica, Aversa", ph: "IMG · facciata restaurata edificio storico", span: "", img: "/img/lavoro-facciata.jpg" },
  { cat: "Residenziale", t: "Villa, costiera", ph: "IMG · villa con finiture pregiate, esterni", span: "tall", img: "/img/lavoro-villa.jpg" },
  { cat: "Opere", t: "Intervento strutturale", ph: "IMG · cantiere tecnico / consolidamento strutturale", span: "wide", img: "/img/lavoro-strutturale.jpg" },
];
---

<section class="section portfolio" id="portfolio">
  <div class="container">
    <div class="head portfolio__head">
      <p class="label" data-reveal>Lavori selezionati</p>
      <h2 class="head__title" data-reveal>La precisione si vede.<br />Anche a lavoro finito.</h2>
    </div>

    <ul class="portfolio__grid">
      {lavori.map((l) => (
        <li class={`work ${l.span ? "work--" + l.span : ""}`} data-reveal>
          <div class="ph work__img" data-ph={l.ph}>
            <img src={l.img} alt={l.t} loading="lazy" data-parallax-soft onerror="this.remove()" />
          </div>
          <div class="work__meta">
            <span class="label">{l.cat}</span>
            <h3 class="work__t">{l.t}</h3>
          </div>
        </li>
      ))}
    </ul>

    <p class="portfolio__foot" data-reveal>
      Galleria in aggiornamento — <a href="#contatti" class="gold">richiedi il portfolio completo</a>.
    </p>
  </div>
</section>

<style>
  .portfolio__head { margin-bottom: var(--space-2xl); }
  .portfolio__grid {
    display: grid; grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-auto-rows: 14rem; gap: var(--space-md);
  }
  .work {
    grid-column: span 2; position: relative; overflow: hidden;
    border-radius: var(--radius-md); border: 1px solid var(--color-line);
  }
  .work--wide { grid-column: span 3; }
  .work--tall { grid-row: span 2; }
  .work__img { position: absolute; inset: 0; border: 0; border-radius: 0; }
  .work__img img { height: 120%; inset-block-start: -10%; }
  .work__meta {
    position: absolute; inset-inline: 0; inset-block-end: 0; z-index: 2;
    padding: var(--space-lg);
    background: linear-gradient(0deg, oklch(10% 0.004 60 / 0.85), transparent);
    transform: translateY(8px); opacity: 0.92;
    transition: transform var(--dur-mid) var(--ease-out), opacity var(--dur-mid) var(--ease-out);
  }
  .work:hover .work__meta { transform: translateY(0); opacity: 1; }
  .work__t { font-family: var(--font-display); text-transform: uppercase; font-size: var(--text-xl); margin-top: 0.25rem; }
  .work::after {
    content: ""; position: absolute; inset: 0; z-index: 1;
    box-shadow: inset 0 0 0 0 var(--color-accent);
    transition: box-shadow var(--dur-mid) var(--ease-out); pointer-events: none;
  }
  .work:hover::after { box-shadow: inset 0 0 0 2px var(--color-accent); }
  .portfolio__foot { margin-top: var(--space-2xl); color: var(--color-fg-dim); text-align: center; }
  .portfolio__foot a { text-decoration: underline; text-underline-offset: 3px; }

  @media (max-width: 820px) {
    .portfolio__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); grid-auto-rows: 12rem; }
    .work, .work--wide { grid-column: span 2; }
    .work--tall { grid-row: span 1; }
  }
  @media (max-width: 520px) {
    .portfolio__grid { grid-template-columns: 1fr; }
    .work, .work--wide { grid-column: span 1; }
  }
</style>
