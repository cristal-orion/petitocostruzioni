---
// Icone (stroke, currentColor) per le 3 fasi
const icons = {
  clock: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-2.9 7.6-7 9-4.1-1.4-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>`,
  compass: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M15.6 8.4l-2.1 5.1-5.1 2.1 2.1-5.1 5.1-2.1z"/></svg>`,
};

const pilastri = [
  {
    k: "Tranquillità",
    icon: "clock",
    titolo: "Tempi e modalità su cui contare",
    testo:
      "Manodopera in regola e un'azienda abituata ai controlli continui delle commesse pubbliche più esigenti. Quando affidi un lavoro a Petito, sai già come finirà.",
  },
  {
    k: "Responsabilità",
    icon: "shield",
    titolo: "Non solo estetica: sicurezza",
    testo:
      "Infiltrazioni, distacchi, facciate degradate, danni strutturali sottovalutati. Rimandare certi interventi costa molto più del lavoro stesso.",
  },
  {
    k: "Competenza",
    icon: "compass",
    titolo: "Per i lavori che non perdonano",
    testo:
      "Edifici storici, consolidamenti, impiantistica complessa, cantieri in contesti abitati. Alcuni interventi richiedono più di una semplice impresa edile.",
  },
];
---

<section class="section section--light perche" id="perche">
  <div class="container">
    <div class="perche__top">
      <p class="label" data-reveal>Perché Petito</p>
      <h2 class="perche__statement display" data-reveal>
        Il problema non è iniziare i lavori.<br />
        È scegliere <span class="gold">a chi affidarli.</span>
      </h2>
    </div>

    {/* TODO: quando il titolare invia la foto reale del team/titolare,
        inserire qui sopra la griglia un blocco "chi c'è dietro i lavori"
        (foto + breve testo). Predisposizione lasciata volutamente vuota. */}

    <div class="perche__grid">
      {pilastri.map((p, i) => (
        <article class="pilastro" data-reveal>
          <div class="pilastro__head">
            <span class="pilastro__icon" aria-hidden="true" set:html={icons[p.icon]}></span>
            <span class="pilastro__idx label">0{i + 1}</span>
          </div>
          <h3 class="pilastro__k">{p.k}</h3>
          <p class="pilastro__t">{p.titolo}</p>
          <p class="pilastro__d">{p.testo}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .perche__top { max-width: none; margin-bottom: var(--space-3xl); }
  .perche__statement {
    font-family: var(--font-display); text-transform: uppercase;
    font-size: clamp(2rem, 1.1rem + 3.4vw, 3.6rem); line-height: 1.3; letter-spacing: -0.01em;
    margin-top: var(--space-md); max-width: none; text-wrap: balance;
  }
  .perche__grid {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-xl); border-top: 1px solid var(--color-line-light); padding-top: var(--space-xl);
  }
  .pilastro { display: flex; flex-direction: column; gap: var(--space-sm); }
  .pilastro__head { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-xs); }
  .pilastro__icon { display: inline-flex; color: var(--color-accent-deep); }
  .pilastro__icon :global(svg) { width: 30px; height: 30px; display: block; }
  .pilastro__idx { color: var(--color-accent-deep); }
  .pilastro__k {
    font-family: var(--font-display); text-transform: uppercase;
    font-size: var(--text-2xl); letter-spacing: 0.01em; line-height: 1;
  }
  .pilastro__t { font-weight: 700; font-size: var(--text-lg); color: var(--color-ink); }
  .pilastro__d { color: oklch(34% 0.012 70); font-size: var(--text-sm); line-height: 1.6; }

  @media (max-width: 820px) { .perche__grid { grid-template-columns: 1fr; gap: var(--space-2xl); } }
</style>
