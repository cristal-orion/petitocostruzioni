---
// Dati reali da biglietto da visita / presentazione società.
const azienda = {
  ref: "Geom. Petito Crescenzo",
  tel: "+39 389 349 1366",
  telRaw: "+393893491366",
  email: "petitocostruzioni@blu.it",
  pec: "petito.costruzioni@pec.it",
  indirizzo: "Via del Caravaggio 22 — 81030 Cesa (CE)",
  piva: "07390231210",
  univoco: "KRRH6B9",
};
---

<section class="section contatti" id="contatti">
  <div class="container contatti__grid">
    <div class="contatti__intro">
      <p class="label" data-reveal>Iniziamo</p>
      <h2 class="contatti__title display" data-reveal>
        Raccontaci<br /><span class="gold">l'intervento.</span>
      </h2>
      <p class="contatti__lede" data-reveal>
        Un sopralluogo, una valutazione onesta e un preventivo chiaro.
        Nessun impegno: solo la certezza di parlare con chi sa di cosa parla.
      </p>

      <dl class="contatti__data" data-reveal>
        <div><dt class="label">Referente</dt><dd>{azienda.ref}</dd></div>
        <div><dt class="label">Telefono</dt><dd><a href={`tel:${azienda.telRaw}`}>{azienda.tel}</a></dd></div>
        <div><dt class="label">Email</dt><dd><a href={`mailto:${azienda.email}`}>{azienda.email}</a></dd></div>
        <div><dt class="label">PEC</dt><dd>{azienda.pec}</dd></div>
        <div><dt class="label">Sede</dt><dd>{azienda.indirizzo}</dd></div>
        <div><dt class="label">P. IVA</dt><dd>{azienda.piva}</dd></div>
      </dl>
    </div>

    <form
      class="form"
      data-reveal
      method="POST"
      action="#"
      data-action-note="Collega qui Formspree/Netlify Forms o l'endpoint email"
    >
      <div class="form__row">
        <label class="field">
          <span class="field__label">Nome e cognome</span>
          <input type="text" name="nome" required autocomplete="name" placeholder="Mario Rossi" />
        </label>
        <label class="field">
          <span class="field__label">Telefono</span>
          <input type="tel" name="telefono" required autocomplete="tel" placeholder="+39 ..." />
        </label>
      </div>

      <label class="field">
        <span class="field__label">Email</span>
        <input type="email" name="email" required autocomplete="email" placeholder="nome@azienda.it" />
      </label>

      <label class="field">
        <span class="field__label">Tipo di intervento</span>
        <select name="tipo" required>
          <option value="" disabled selected>Seleziona…</option>
          <option>Ristrutturazione residenziale</option>
          <option>Studio medico / dentistico</option>
          <option>Spazio business / ufficio</option>
          <option>Restauro / consolidamento</option>
          <option>Altro</option>
        </select>
      </label>

      <label class="field">
        <span class="field__label">Descrivi il progetto</span>
        <textarea name="messaggio" rows="4" placeholder="Dove, cosa e in che tempi…"></textarea>
      </label>

      <button type="submit" class="btn form__submit">
        Invia richiesta <span class="btn__arrow" aria-hidden="true">→</span>
      </button>
      <p class="form__hint" data-form-status>Risposta in genere entro 24/48h lavorative.</p>
    </form>
  </div>
</section>

<style>
  .contatti { background: var(--color-bg-2); }
  .contatti__grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3xl); align-items: start; }
  .contatti__title { font-family: var(--font-display); text-transform: uppercase; font-size: var(--text-display); line-height: 0.95; margin-block: var(--space-md) var(--space-lg); }
  .contatti__lede { color: var(--color-fg-dim); font-size: var(--text-lg); max-width: 38ch; margin-bottom: var(--space-2xl); }
  .contatti__data { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); border-top: 1px solid var(--color-line); padding-top: var(--space-lg); }
  .contatti__data dt { margin-bottom: 0.3rem; }
  .contatti__data dd { font-size: var(--text-sm); }
  .contatti__data a { border-bottom: 1px solid var(--color-line-strong); transition: border-color var(--dur-fast) var(--ease-out); }
  .contatti__data a:hover { border-color: var(--color-accent); }

  .form { background: var(--color-bg); border: 1px solid var(--color-line); border-radius: var(--radius-lg); padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-md); }
  .form__row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field__label { font-family: var(--font-mono); font-size: var(--text-2xs); letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-fg-dim); }
  .field input, .field select, .field textarea {
    width: 100%; background: var(--color-bg-2); border: 1px solid var(--color-line);
    border-radius: var(--radius-md); padding: 0.8rem 0.9rem; color: var(--color-fg);
    font-size: var(--text-base); transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .field textarea { resize: vertical; min-height: 6rem; }
  .field input::placeholder, .field textarea::placeholder { color: var(--color-fg-faint); }
  .field input:hover, .field select:hover, .field textarea:hover { border-color: var(--color-line-strong); }
  .field input:focus-visible, .field select:focus-visible, .field textarea:focus-visible { outline: none; border-color: var(--color-accent); background: var(--color-bg-3); }
  .field input:invalid:not(:placeholder-shown) { border-color: oklch(58% 0.16 28); }
  .form__submit { margin-top: var(--space-xs); justify-content: center; }
  .form__hint { font-size: var(--text-xs); color: var(--color-fg-faint); text-align: center; }
  .form__hint.is-success { color: var(--color-accent); }
  .form__hint.is-error { color: oklch(68% 0.16 28); }

  @media (max-width: 820px) {
    .contatti__grid { grid-template-columns: 1fr; gap: var(--space-2xl); }
  }
  @media (max-width: 480px) {
    .form__row, .contatti__data { grid-template-columns: 1fr; }
    .form { padding: var(--space-lg); }
  }
</style>
