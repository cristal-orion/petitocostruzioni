---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Petito Costruzioni — Impresa edile di precisione",
  description = "Ristrutturazioni e costruzioni di alto livello per privati e aziende in Campania, Lazio e Abruzzo. Dal 1970.",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const socialImageUrl = new URL("/social-card.jpg", Astro.site);
---

<!doctype html>
<html lang="it" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/brand/logo-oro.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Petito Costruzioni" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:secure_url" content={socialImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Petito Costruzioni — Costruiamo certezze." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Manrope:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // swap no-js -> js as early as possible to avoid FOUC of reveals
      document.documentElement.classList.remove("no-js");
    </script>
  </head>
  <body>
    <a href="#contatti" class="vh">Salta al modulo contatti</a>
    <slot />
  </body>
</html>
