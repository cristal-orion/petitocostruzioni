---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Petito Costruzioni — Impresa edile di precisione | Campania · Lazio · Abruzzo",
  description = "Ristrutturazioni e costruzioni di alto livello per privati e aziende. Tempistiche certe, manodopera in regola, esperienza su commesse NATO, Genio Militare e Ministero della Difesa.",
} = Astro.props;
---

<!doctype html>
<html lang="it" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/brand/logo-oro.png" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="it_IT" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Manrope:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // swap no-js -> js as early as possible to avoid FOUC of reveals
      document.documentElement.classList.remove("no-js");
    </script>
  </head>
  <body>
    <a href="#contatti" class="vh">Salta al modulo contatti</a>
    <slot />
  </body>
</html>
